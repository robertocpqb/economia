# 3. Qual foi a variação média mensal de 2020? E a de 2024?
#region

df_copper = df_copper.sort_values("Data").dropna(subset=["Data", "Cotação"])

# Último preço de cada mês (para retorno mensal)
mensal_last = df_copper.set_index("Data")["Cotação"].resample("M").last()

# Retorno mensal em %
ret_mensal = mensal_last.pct_change() * 100

# Transforma em DataFrame e separa Ano/Mês
ret_mensal = ret_mensal.dropna().to_frame("RetornoMensal_%").reset_index()
ret_mensal["Ano"] = ret_mensal["Data"].dt.year
ret_mensal["Mês"] = ret_mensal["Data"].dt.month

# Média mensal (em %) para 2020 e 2024
media_2020 = ret_mensal.loc[ret_mensal["Ano"] == 2020, "RetornoMensal_%"].mean()
media_2024 = ret_mensal.loc[ret_mensal["Ano"] == 2024, "RetornoMensal_%"].mean()

print(ret_mensal)
print("Variação média mensal em 2020 (%):", media_2020.round(2))
print("Variação média mensal em 2024 (%):", media_2024.round(2))


#endregion



# 4. Qual foi a variação acumulada entre 02/01/2020 e 31/12/2025?
#region

df_copper["Data"] = pd.to_datetime(df_copper["Data"])
df_copper["Cotação"] = pd.to_numeric(df_copper["Cotação"], errors="coerce")

inicio = df_copper[df_copper["Data"] >= "2020-01-02"]["Cotação"].iloc[0]
fim = df_copper[df_copper["Data"] <= "2025-12-31"]["Cotação"].iloc[-1]

variacao_acumulada = (fim / inicio) - 1

print(f"Variação acumulada 02/01/2020 e 31/12/2025: {variacao_acumulada:.2%}")

#endregion



